rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Modelo assumido
    // ===============================================================
    // users/{uid}/settings/profile: name (0..120), horários HH:mm,
    // darkMode (bool), updatedAt (timestamp).
    // users/{uid}/days/{YYYY-MM-DD}: campos textuais do registro diário
    // (até 20.000 caracteres), conclusões booleanas e updatedAt.
    // users/{uid}/prayers/{uuid}: name, reason, category, done,
    // createdAt imutável, updatedAt e lastPrayed opcional.
    // users/{uid}/weeks/{YYYY-Www}: cinco campos textuais, savedAt e updatedAt.

    // ===============================================================
    // Funções auxiliares e validadores de domínio
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Mantidas para explicitar a proteção de UID. O modelo usa o UID seguro
    // no caminho e não aceita um campo UID controlado pelo cliente.
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function validText(data, field, maxLength) {
      return data[field] is string && data[field].size() <= maxLength;
    }

    function validUpdatedAt(data) {
      return data.updatedAt is timestamp && data.updatedAt == request.time;
    }

    function isValidSettings(data) {
      return data.keys().hasOnly(['name', 'morningTime', 'practiceTime', 'reviewTime', 'darkMode', 'updatedAt']) &&
        data.keys().hasAll(['name', 'morningTime', 'practiceTime', 'reviewTime', 'darkMode', 'updatedAt']) &&
        validText(data, 'name', 120) &&
        data.morningTime is string && data.morningTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$') &&
        data.practiceTime is string && data.practiceTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$') &&
        data.reviewTime is string && data.reviewTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$') &&
        data.darkMode is bool && validUpdatedAt(data) && uidUnchanged();
    }

    function isValidDay(data, dayId) {
      let textFields = ['devotionalText', 'devotionalMessage', 'devotionalSurrender', 'devotionalPrayer',
        'ebdTitle', 'ebdTopic', 'ebdLearning', 'ebdApplication', 'bibleBook', 'bibleChapter',
        'bibleVerses', 'bibleGod', 'bibleInsight', 'bibleDirection', 'nextBibleReading', 'truthToday',
        'actionToday', 'personToday', 'reviewWhat', 'reviewChrist', 'reviewGrowth', 'reviewTomorrow',
        'reviewGratitude'];
      let checkFields = ['doneDevotional', 'doneEbd', 'doneBible', 'donePractice', 'doneReview'];
      let fields = ['date', 'updatedAt', 'reviewStatus'] + textFields + checkFields;
      return data.keys().hasOnly(fields) && data.keys().hasAll(fields) &&
        data.date is string && data.date == dayId && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
        data.reviewStatus is string && data.reviewStatus in ['', 'sim', 'parcialmente', 'nao'] &&
        validText(data, 'devotionalText', 500) && validText(data, 'devotionalMessage', 20000) &&
        validText(data, 'devotionalSurrender', 20000) && validText(data, 'devotionalPrayer', 20000) &&
        validText(data, 'ebdTitle', 500) && validText(data, 'ebdTopic', 500) &&
        validText(data, 'ebdLearning', 20000) && validText(data, 'ebdApplication', 20000) &&
        validText(data, 'bibleBook', 200) && validText(data, 'bibleChapter', 50) &&
        validText(data, 'bibleVerses', 100) && validText(data, 'bibleGod', 20000) &&
        validText(data, 'bibleInsight', 20000) && validText(data, 'bibleDirection', 20000) &&
        validText(data, 'nextBibleReading', 500) && validText(data, 'truthToday', 5000) &&
        validText(data, 'actionToday', 5000) && validText(data, 'personToday', 500) &&
        validText(data, 'reviewWhat', 10000) && validText(data, 'reviewChrist', 10000) &&
        validText(data, 'reviewGrowth', 10000) && validText(data, 'reviewTomorrow', 10000) &&
        validText(data, 'reviewGratitude', 5000) &&
        data.doneDevotional is bool && data.doneEbd is bool && data.doneBible is bool &&
        data.donePractice is bool && data.doneReview is bool && validUpdatedAt(data) && uidUnchanged();
    }

    function isValidPrayer(data, prayerId) {
      return data.keys().hasOnly(['id', 'name', 'reason', 'category', 'createdAt', 'updatedAt', 'lastPrayed', 'done']) &&
        data.keys().hasAll(['id', 'name', 'reason', 'category', 'createdAt', 'updatedAt', 'lastPrayed', 'done']) &&
        data.id is string && data.id == prayerId && data.id.size() <= 80 &&
        validText(data, 'name', 300) && data.name.size() > 0 &&
        validText(data, 'reason', 10000) && data.reason.size() > 0 &&
        data.category is string && data.category in ['Família', 'Igreja', 'Enfermos', 'Afastados', 'Trabalho', 'Missões', 'Gratidão', 'Outro'] &&
        data.createdAt is timestamp && data.createdAt <= request.time &&
        (data.lastPrayed == null || (data.lastPrayed is timestamp && data.lastPrayed <= request.time)) &&
        data.done is bool && validUpdatedAt(data) && uidUnchanged();
    }

    function isValidWeek(data, weekId) {
      return data.keys().hasOnly(['week', 'weeklyLearning', 'weeklyPractice', 'weeklyDifficulty', 'weeklyPerson', 'weeklyFocus', 'savedAt', 'updatedAt']) &&
        data.keys().hasAll(['week', 'weeklyLearning', 'weeklyPractice', 'weeklyDifficulty', 'weeklyPerson', 'weeklyFocus', 'savedAt', 'updatedAt']) &&
        data.week is string && data.week == weekId && data.week.matches('^[0-9]{4}-W[0-9]{2}$') &&
        validText(data, 'weeklyLearning', 20000) && validText(data, 'weeklyPractice', 20000) &&
        validText(data, 'weeklyDifficulty', 20000) && validText(data, 'weeklyPerson', 500) &&
        validText(data, 'weeklyFocus', 20000) && data.savedAt is timestamp &&
        data.savedAt <= request.time && validUpdatedAt(data) && uidUnchanged();
    }

    match /users/{userId} {
      allow read, write: if false;

      match /settings/{settingsId} {
        allow read, delete: if isOwner(userId) && settingsId == 'profile';
        allow create: if isOwner(userId) && settingsId == 'profile' && isValidSettings(request.resource.data);
        allow update: if isOwner(userId) && settingsId == 'profile' && isValidSettings(request.resource.data) && uidNotModified();
      }

      match /days/{dayId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDay(request.resource.data, dayId);
        allow update: if isOwner(userId) && isValidDay(request.resource.data, dayId) && uidNotModified();
      }

      match /prayers/{prayerId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPrayer(request.resource.data, prayerId);
        allow update: if isOwner(userId) && isValidPrayer(request.resource.data, prayerId) &&
          request.resource.data.createdAt == resource.data.createdAt && uidNotModified();
      }

      match /weeks/{weekId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWeek(request.resource.data, weekId);
        allow update: if isOwner(userId) && isValidWeek(request.resource.data, weekId) && uidNotModified();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
